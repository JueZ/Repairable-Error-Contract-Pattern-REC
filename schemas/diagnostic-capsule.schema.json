{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repairable-error-contract.dev/schemas/diagnostic-capsule.schema.json",
  "title": "DiagnosticCapsule",
  "description": "Private sanitized diagnostic evidence package used by a Repairable Error Contract analyzer. This object is not returned publicly. Schema validation is not a substitute for allowlisted construction and non-leakage tests.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rec_version",
    "diagnostic_id",
    "operation_id",
    "endpoint",
    "method",
    "failure_stage",
    "http_status",
    "safe_error",
    "request_shape",
    "contract_summary",
    "safe_examples",
    "security_policy"
  ],
  "properties": {
    "rec_version": {
      "type": "string",
      "pattern": "^0\\.1\\.[0-9]+$"
    },
    "diagnostic_id": {
      "type": "string",
      "maxLength": 100
    },
    "operation_id": {
      "type": "string",
      "maxLength": 100
    },
    "endpoint": {
      "type": "string",
      "maxLength": 200
    },
    "method": {
      "type": "string",
      "enum": [
        "GET",
        "HEAD",
        "POST",
        "PUT",
        "PATCH",
        "DELETE",
        "OPTIONS"
      ]
    },
    "failure_stage": {
      "type": "string",
      "enum": [
        "json_parse",
        "request_shape",
        "input_validation",
        "business_rule",
        "authorization",
        "upstream",
        "dependency",
        "internal",
        "unknown"
      ]
    },
    "http_status": {
      "type": "integer",
      "minimum": 400,
      "maximum": 599
    },
    "trace_id": {
      "type": "string",
      "maxLength": 160
    },
    "public_existence_policy": {
      "type": "string",
      "enum": [
        "may_disclose_not_found",
        "hide_existence_as_404",
        "generic_denial"
      ],
      "description": "Policy hint for 403/404 resource-existence disclosure decisions."
    },
    "allowed_request_paths": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "$ref": "#/$defs/jsonPointer"
      }
    },
    "allowed_operation_ids": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "string",
        "maxLength": 100
      }
    },
    "safe_error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "maxLength": 120
        },
        "message": {
          "type": "string",
          "maxLength": 700,
          "description": "Sanitized message. Do not pass through raw upstream messages without review."
        },
        "original_status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        }
      }
    },
    "request_shape": {
      "type": "object",
      "description": "Shape-only representation of the request. Values must not be exposed.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "value_exposed"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "undefined",
              "null",
              "string",
              "number",
              "integer",
              "boolean",
              "array",
              "object",
              "unknown"
            ]
          },
          "length_bucket": {
            "type": "string",
            "enum": [
              "empty",
              "short",
              "medium",
              "long"
            ]
          },
          "value_exposed": {
            "type": "boolean",
            "const": false
          }
        }
      }
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "properties"
      ],
      "properties": {
        "required": {
          "type": "array",
          "maxItems": 100,
          "items": {
            "type": "string",
            "maxLength": 120
          }
        },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "maxLength": 80
              },
              "format": {
                "type": "string",
                "maxLength": 80
              },
              "nullable": {
                "type": "boolean"
              },
              "accepted_formats": {
                "type": "array",
                "maxItems": 20,
                "items": {
                  "type": "string",
                  "maxLength": 160
                }
              },
              "enum_values": {
                "type": "array",
                "maxItems": 50,
                "items": {
                  "type": "string",
                  "maxLength": 160
                }
              },
              "description": {
                "type": "string",
                "maxLength": 400
              }
            }
          }
        },
        "aliases": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "maxLength": 120
          }
        }
      }
    },
    "safe_examples": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "maxProperties": 50,
        "additionalProperties": {
          "$ref": "#/$defs/safeJson"
        }
      }
    },
    "security_policy": {
      "type": "object",
      "description": "Audit metadata for the capsule builder. These flags do not prove safety; producers must enforce them in construction and tests.",
      "additionalProperties": false,
      "required": [
        "capsule_source",
        "raw_request_body_included",
        "authorization_headers_included",
        "tokens_included",
        "stack_trace_included",
        "raw_upstream_response_included",
        "return_only_schema_valid_problem"
      ],
      "properties": {
        "capsule_source": {
          "type": "string",
          "const": "allowlist"
        },
        "raw_request_body_included": {
          "type": "boolean",
          "const": false
        },
        "authorization_headers_included": {
          "type": "boolean",
          "const": false
        },
        "tokens_included": {
          "type": "boolean",
          "const": false
        },
        "stack_trace_included": {
          "type": "boolean",
          "const": false
        },
        "raw_upstream_response_included": {
          "type": "boolean",
          "const": false
        },
        "return_only_schema_valid_problem": {
          "type": "boolean",
          "const": true
        }
      }
    }
  },
  "$defs": {
    "jsonPointer": {
      "type": "string",
      "maxLength": 180,
      "pattern": "^(|(/([^/~]|~0|~1)*)*)$"
    },
    "safeJson": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 300
        },
        {
          "type": "array",
          "maxItems": 50,
          "items": {
            "$ref": "#/$defs/safeJson"
          }
        },
        {
          "type": "object",
          "maxProperties": 50,
          "additionalProperties": {
            "$ref": "#/$defs/safeJson"
          }
        }
      ]
    }
  }
}
